# ──────────────────────────────────────────────────────────────
# AlphaMind environment configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
REQUEST_TIMEOUT=60

# ── Financial data providers ──
# Financial Modeling Prep (https://site.financialmodelingprep.com/developer) — optional.
# Leave blank to disable FMP; Yahoo + SEC EDGAR still work without any key.
FMP_API_KEY=
# SEC EDGAR requires a descriptive User-Agent WITH a real contact email.
SEC_USER_AGENT=AlphaMind/0.1 (contact: set-your-email@example.com)
# Toggle providers and snapshot cache TTL (seconds).
ENABLE_YAHOO=true
ENABLE_EDGAR=true
ENABLE_FMP=true
DATA_CACHE_TTL=3600

# ── RAG over SEC filings (LangChain + Qdrant + OpenAI embeddings) ──
ENABLE_RAG=false
EMBEDDING_MODEL=text-embedding-3-small
QDRANT_COLLECTION=alphamind_filings
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5
# Choose ONE Qdrant backend (leave all blank for ephemeral in-memory dev store):
#   - Hosted/server:  QDRANT_URL=http://localhost:6333  (+ QDRANT_API_KEY for cloud)
#   - On-disk local:  QDRANT_PATH=./qdrant_data
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PATH=

# ── Multi-agent debate ──
DEBATE_ROUNDS=2

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000

# Streamlit -> API base URL
ALPHAMIND_API_URL=http://localhost:8000

# Observability
LOG_LEVEL=INFO

# Optional: LangSmith tracing (recommended in prod)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-your-key-here
# LANGCHAIN_PROJECT=alphamind
